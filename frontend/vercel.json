{
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "https://schedulix-io.onrender.com/api/$1"
        },
        {
            "source": "/docs",
            "destination": "https://schedulix-io.onrender.com/docs"
        },
        {
            "source": "/openapi.json",
            "destination": "https://schedulix-io.onrender.com/openapi.json"
        },
        {
            "source": "/health",
            "destination": "https://schedulix-io.onrender.com/health"
        },
        {
            "source": "/health/docs",
            "destination": "https://schedulix-io.onrender.com/health/docs"
        },
        {
            "source": "/",
            "destination": "/login.html"
        },
        {
            "source": "/login",
            "destination": "/login.html"
        },
        {
            "source": "/register",
            "destination": "/register.html"
        },
        {
            "source": "/dashboard",
            "destination": "/dashboard.html"
        },
        {
            "source": "/tasks",
            "destination": "/tasks_todo.html"
        },
        {
            "source": "/add-task",
            "destination": "/add_task.html"
        },
        {
            "source": "/routine",
            "destination": "/routine.html"
        },
        {
            "source": "/notifications",
            "destination": "/notifications.html"
        }
    ]
}
